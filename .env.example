# Sound Realty API - Environment Configuration Example
# Copy this file to .env and update values as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_WORKER_CLASS=uvicorn.workers.UvicornWorker

# Model Configuration
MODEL_PATH=model/model.pkl
FEATURES_PATH=model/model_features.json
FEATURES_TYPES_PATH=model/model_features_with_types.json

# Data Configuration
DEMOGRAPHICS_PATH=data/zipcode_demographics.csv

# Logging
LOG_LEVEL=INFO

# Development
DEBUG=False
